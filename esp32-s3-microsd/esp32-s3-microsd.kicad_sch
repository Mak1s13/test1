  (text "ESP32-S3 GPIO Connections:\n\nGPIO18 = SD_CLK\nGPIO23 = SD_MOSI\nGPIO19 = SD_MISO\nGPIO5 = SD_CS\n\nDecoupling:\nC1 = 100nF (close to socket)\nC2 = 10uF (bulk)\n\nPull-ups (47k):\nR1 = SD_CS\nR2 = SD_MOSI\nR3 = SD_MISO"
